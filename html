<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MD-Tech | פתרונות איטום ואינסטלציה מתקדמים</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700;900&family=Assistant:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink:       #0d1117;
    --steel:     #1c2433;
    --panel:     #1e2a3a;
    --accent:    #0ea5e9;
    --accent2:   #f97316;
    --light:     #f0f6ff;
    --muted:     #8ca0b8;
    --white:     #ffffff;
    --radius:    10px;
    --transition: 0.3s ease;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Assistant', sans-serif;
    background: var(--ink);
    color: var(--light);
    font-size: 17px;
    line-height: 1.7;
    direction: rtl;
  }

  /* ─── STICKY BAR ─── */
  .sticky-bar {
    position: fixed; top: 0; width: 100%; z-index: 1000;
    background: var(--accent2);
    padding: 9px 20px;
    display: flex; align-items: center; justify-content: center; gap: 16px;
    font-family: 'Heebo', sans-serif; font-weight: 700; font-size: 15px;
    box-shadow: 0 2px 12px rgba(249,115,22,.4);
  }
  .sticky-bar a { color: #fff; text-decoration: none; letter-spacing: .3px; }
  .sticky-bar .pulse {
    width: 10px; height: 10px; border-radius: 50%; background: #fff;
    animation: pulse 1.6s infinite;
  }
  @keyframes pulse {
    0%,100%{opacity:1;transform:scale(1)}
    50%{opacity:.5;transform:scale(1.4)}
  }

  /* ─── NAV ─── */
  nav {
    position: sticky; top: 38px; z-index: 999;
    background: rgba(13,17,23,.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(14,165,233,.15);
    padding: 14px 40px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo {
    font-family: 'Heebo', sans-serif; font-weight: 900; font-size: 22px;
    color: var(--accent); letter-spacing: -1px;
  }
  .nav-logo span { color: var(--accent2); }
  .nav-links { display: flex; gap: 28px; list-style: none; }
  .nav-links a {
    color: var(--muted); text-decoration: none; font-size: 14px; font-weight: 600;
    transition: color var(--transition);
  }
  .nav-links a:hover { color: var(--white); }
  .nav-cta {
    background: var(--accent); color: #fff; border: none; border-radius: 6px;
    padding: 9px 20px; font-weight: 700; font-size: 14px; cursor: pointer;
    font-family: 'Heebo', sans-serif; text-decoration: none;
    transition: background var(--transition);
  }
  .nav-cta:hover { background: #0284c7; }

  /* ─── HERO ─── */
  .hero {
    min-height: 92vh;
    background:
      radial-gradient(ellipse 80% 60% at 60% 40%, rgba(14,165,233,.13) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 10% 80%, rgba(249,115,22,.08) 0%, transparent 60%),
      var(--ink);
    display: flex; flex-direction: column; justify-content: center;
    padding: 80px 60px 60px;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image: repeating-linear-gradient(
      0deg, transparent, transparent 59px,
      rgba(14,165,233,.04) 60px
    ),
    repeating-linear-gradient(
      90deg, transparent, transparent 59px,
      rgba(14,165,233,.04) 60px
    );
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(14,165,233,.12); border: 1px solid rgba(14,165,233,.3);
    border-radius: 40px; padding: 6px 18px;
    font-size: 13px; font-weight: 700; color: var(--accent);
    margin-bottom: 24px; width: fit-content;
  }
  .hero h1 {
    font-family: 'Heebo', sans-serif;
    font-size: clamp(32px, 5vw, 62px);
    font-weight: 900; line-height: 1.15;
    max-width: 760px; margin-bottom: 20px;
  }
  .hero h1 em { font-style: normal; color: var(--accent); }
  .hero p {
    font-size: 18px; color: var(--muted); max-width: 560px; margin-bottom: 36px;
  }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn-primary {
    background: var(--accent); color: #fff; text-decoration: none;
    padding: 15px 32px; border-radius: 8px;
    font-family: 'Heebo', sans-serif; font-weight: 800; font-size: 16px;
    display: inline-flex; align-items: center; gap: 8px;
    box-shadow: 0 0 30px rgba(14,165,233,.3);
    transition: all var(--transition);
  }
  .btn-primary:hover { background: #0284c7; transform: translateY(-2px); box-shadow: 0 8px 30px rgba(14,165,233,.4); }
  .btn-wa {
    background: #25d366; color: #fff; text-decoration: none;
    padding: 15px 32px; border-radius: 8px;
    font-family: 'Heebo', sans-serif; font-weight: 800; font-size: 16px;
    display: inline-flex; align-items: center; gap: 8px;
    transition: all var(--transition);
  }
  .btn-wa:hover { background: #1bb856; transform: translateY(-2px); }
  .btn-ghost {
    border: 1px solid rgba(140,160,184,.3); color: var(--muted); text-decoration: none;
    padding: 15px 28px; border-radius: 8px;
    font-family: 'Heebo', sans-serif; font-weight: 700; font-size: 15px;
    display: inline-flex; align-items: center; gap: 8px;
    transition: all var(--transition);
  }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }
  .hero-trust {
    margin-top: 50px;
    display: flex; gap: 40px; flex-wrap: wrap;
  }
  .trust-item { display: flex; align-items: center; gap: 10px; }
  .trust-icon { font-size: 22px; }
  .trust-text strong { display: block; font-size: 20px; font-weight: 900; color: var(--white); font-family: 'Heebo', sans-serif; }
  .trust-text span { font-size: 12px; color: var(--muted); }

  /* ─── SECTIONS ─── */
  section { padding: 90px 60px; }
  .section-label {
    display: inline-block; font-size: 12px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 2px; color: var(--accent);
    margin-bottom: 12px;
  }
  h2 {
    font-family: 'Heebo', sans-serif; font-weight: 900;
    font-size: clamp(26px, 3.5vw, 42px); color: var(--white); line-height: 1.2;
    margin-bottom: 14px;
  }
  h2 em { font-style: normal; color: var(--accent); }
  .section-sub { color: var(--muted); font-size: 17px; max-width: 540px; margin-bottom: 56px; }
  .section-header { margin-bottom: 56px; }

  /* ─── WHY US (stats row) ─── */
  .why-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;
  }
  .why-card {
    background: var(--panel);
    border: 1px solid rgba(14,165,233,.12);
    border-radius: var(--radius);
    padding: 30px 24px;
    transition: all var(--transition);
    position: relative; overflow: hidden;
  }
  .why-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(14,165,233,.06) 0%, transparent 60%);
    opacity: 0; transition: opacity var(--transition);
  }
  .why-card:hover { border-color: rgba(14,165,233,.3); transform: translateY(-4px); }
  .why-card:hover::before { opacity: 1; }
  .why-icon { font-size: 30px; margin-bottom: 14px; }
  .why-card h3 { font-size: 15px; font-weight: 700; color: var(--white); margin-bottom: 8px; }
  .why-card p { font-size: 14px; color: var(--muted); line-height: 1.6; }

  /* ─── SERVICES ─── */
  .services-bg { background: var(--steel); }
  .service-groups { display: flex; flex-direction: column; gap: 50px; }
  .service-group-label {
    display: flex; align-items: center; gap: 14px; margin-bottom: 24px;
  }
  .service-group-label .group-icon {
    width: 44px; height: 44px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
  }
  .group-diagnose .group-icon { background: rgba(14,165,233,.15); }
  .group-treat .group-icon  { background: rgba(249,115,22,.15); }
  .group-rehab .group-icon  { background: rgba(34,197,94,.15); }
  .service-group-label h3 {
    font-family: 'Heebo', sans-serif; font-weight: 900; font-size: 20px;
  }
  .service-group-label span { color: var(--muted); font-size: 14px; }
  .service-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
  .service-card {
    background: var(--ink);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: var(--radius); padding: 24px 20px;
    transition: all var(--transition);
  }
  .service-card:hover { border-color: rgba(14,165,233,.25); transform: translateY(-3px); }
  .service-card .s-icon { font-size: 28px; margin-bottom: 12px; }
  .service-card h4 { font-size: 16px; font-weight: 700; color: var(--white); margin-bottom: 8px; }
  .service-card p { font-size: 14px; color: var(--muted); line-height: 1.6; }

  /* ─── HOW IT WORKS ─── */
  .steps { display: flex; flex-direction: column; gap: 0; position: relative; }
  .steps::before {
    content: ''; position: absolute;
    right: 23px; top: 0; bottom: 0; width: 2px;
    background: linear-gradient(to bottom, var(--accent), transparent);
  }
  .step {
    display: flex; gap: 28px; align-items: flex-start;
    padding: 0 0 40px 0; position: relative;
  }
  .step-num {
    flex-shrink: 0; width: 48px; height: 48px;
    background: var(--panel); border: 2px solid var(--accent);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-family: 'Heebo', sans-serif; font-weight: 900; font-size: 18px; color: var(--accent);
    position: relative; z-index: 1;
  }
  .step-content h3 { font-size: 18px; font-weight: 700; color: var(--white); margin-bottom: 6px; padding-top: 10px; }
  .step-content p { font-size: 15px; color: var(--muted); }
  .step-content .step-time {
    display: inline-block; margin-top: 8px;
    font-size: 12px; font-weight: 700; color: var(--accent);
    background: rgba(14,165,233,.1); border-radius: 4px; padding: 3px 10px;
  }

  /* ─── COMPARISON ─── */
  .compare-bg { background: var(--steel); }
  .compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; max-width: 860px; }
  .compare-col {
    border-radius: var(--radius); padding: 32px 28px;
  }
  .compare-col.good {
    background: rgba(14,165,233,.08); border: 1px solid rgba(14,165,233,.25);
  }
  .compare-col.bad {
    background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07);
  }
  .compare-col h3 { font-size: 18px; font-weight: 800; margin-bottom: 20px; font-family: 'Heebo', sans-serif; }
  .compare-col.good h3 { color: var(--accent); }
  .compare-col.bad h3  { color: var(--muted); }
  .compare-item { display: flex; gap: 12px; margin-bottom: 14px; font-size: 15px; }
  .compare-item .ci { flex-shrink: 0; font-size: 16px; margin-top: 2px; }

  /* ─── TESTIMONIALS ─── */
  .testimonials-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
  .testi-card {
    background: var(--panel); border: 1px solid rgba(255,255,255,.07);
    border-radius: var(--radius); padding: 28px 24px;
    position: relative;
  }
  .testi-card::before {
    content: '"'; position: absolute; top: 14px; left: 20px;
    font-size: 60px; color: var(--accent); opacity: .15;
    font-family: 'Heebo', sans-serif; font-weight: 900; line-height: 1;
  }
  .stars { color: #f59e0b; font-size: 14px; margin-bottom: 14px; letter-spacing: 2px; }
  .testi-text { font-size: 15px; color: #c8d8ec; line-height: 1.7; margin-bottom: 18px; }
  .testi-author { display: flex; align-items: center; gap: 12px; }
  .testi-avatar {
    width: 42px; height: 42px; border-radius: 50%;
    background: rgba(14,165,233,.2); display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 900; color: var(--accent);
    font-family: 'Heebo', sans-serif;
  }
  .testi-name { font-weight: 700; font-size: 15px; color: var(--white); }
  .testi-location { font-size: 12px; color: var(--muted); }
  .testi-date { font-size: 12px; color: var(--muted); margin-top: 2px; }

  /* ─── EMERGENCY CTA ─── */
  .emergency-cta {
    background:
      radial-gradient(ellipse 70% 80% at 50% 50%, rgba(249,115,22,.15) 0%, transparent 70%),
      var(--ink);
    border-top: 1px solid rgba(249,115,22,.2);
    border-bottom: 1px solid rgba(249,115,22,.2);
    text-align: center; padding: 80px 40px;
  }
  .emergency-cta h2 { margin-bottom: 10px; }
  .emergency-cta h2 em { color: var(--accent2); }
  .emergency-cta p { color: var(--muted); margin-bottom: 36px; }
  .emergency-actions { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }

  /* ─── GALLERY ─── */
  .gallery-bg { background: var(--steel); }
  .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; }
  .gallery-item {
    aspect-ratio: 4/3;
    border-radius: var(--radius); overflow: hidden;
    background: var(--panel);
    border: 1px solid rgba(255,255,255,.06);
    display: flex; align-items: center; justify-content: center;
    position: relative; cursor: pointer;
    transition: transform var(--transition);
  }
  .gallery-item:hover { transform: scale(1.02); }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; }
  .gallery-item .gallery-placeholder {
    color: var(--muted); font-size: 13px; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
  }
  .gallery-item .gallery-placeholder span { font-size: 28px; }

  /* ─── FAQ ─── */
  .faq-list { max-width: 720px; }
  .faq-item {
    border-bottom: 1px solid rgba(255,255,255,.07);
    overflow: hidden;
  }
  .faq-q {
    width: 100%; background: none; border: none; cursor: pointer;
    text-align: right; padding: 22px 0;
    font-family: 'Heebo', sans-serif; font-weight: 700; font-size: 16px;
    color: var(--white); display: flex; justify-content: space-between;
    align-items: center; gap: 16px;
    transition: color var(--transition);
  }
  .faq-q:hover { color: var(--accent); }
  .faq-arrow {
    flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%;
    background: rgba(14,165,233,.1); border: 1px solid rgba(14,165,233,.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; color: var(--accent); transition: transform var(--transition);
  }
  .faq-item.open .faq-arrow { transform: rotate(180deg); }
  .faq-a { max-height: 0; overflow: hidden; transition: max-height .4s ease, padding .3s ease; }
  .faq-item.open .faq-a { max-height: 300px; }
  .faq-a p { padding: 0 0 22px; font-size: 15px; color: var(--muted); line-height: 1.75; }

  /* ─── CONTACT FORM ─── */
  .contact-bg { background: var(--steel); }
  .contact-layout { display: grid; grid-template-columns: 1fr 1.3fr; gap: 60px; align-items: start; }
  .contact-info h2 { margin-bottom: 16px; }
  .contact-info p { color: var(--muted); font-size: 16px; margin-bottom: 32px; }
  .contact-channels { display: flex; flex-direction: column; gap: 14px; }
  .contact-channel {
    display: flex; align-items: center; gap: 14px;
    background: var(--ink); border: 1px solid rgba(255,255,255,.07);
    border-radius: 10px; padding: 16px 18px; text-decoration: none;
    transition: all var(--transition); color: var(--light);
  }
  .contact-channel:hover { border-color: var(--accent); }
  .cc-icon {
    width: 42px; height: 42px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center; font-size: 18px;
    flex-shrink: 0;
  }
  .cc-phone .cc-icon  { background: rgba(14,165,233,.15); }
  .cc-wa .cc-icon     { background: rgba(37,211,102,.15); }
  .cc-label { font-size: 12px; color: var(--muted); }
  .cc-value { font-weight: 700; font-size: 16px; color: var(--white); }

  /* form */
  .contact-form {
    background: var(--ink); border: 1px solid rgba(14,165,233,.12);
    border-radius: 14px; padding: 36px 32px;
  }
  .form-title { font-family: 'Heebo', sans-serif; font-weight: 800; font-size: 20px; color: var(--white); margin-bottom: 24px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
  .form-group { margin-bottom: 14px; }
  .form-group label { display: block; font-size: 13px; font-weight: 700; color: var(--muted); margin-bottom: 6px; }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%; background: var(--panel);
    border: 1px solid rgba(255,255,255,.08); border-radius: 8px;
    padding: 12px 16px; color: var(--white); font-family: 'Assistant', sans-serif;
    font-size: 15px; outline: none; transition: border-color var(--transition);
    direction: rtl;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus { border-color: var(--accent); }
  .form-group select { cursor: pointer; }
  .form-group textarea { resize: vertical; min-height: 100px; }
  .form-emergency {
    display: flex; align-items: center; gap: 10px;
    background: rgba(249,115,22,.07); border: 1px solid rgba(249,115,22,.2);
    border-radius: 8px; padding: 12px 16px; margin-bottom: 20px; cursor: pointer;
  }
  .form-emergency input[type=checkbox] { width: 18px; height: 18px; accent-color: var(--accent2); cursor: pointer; }
  .form-emergency label { font-size: 14px; font-weight: 600; color: #fed7aa; cursor: pointer; }
  .form-submit {
    width: 100%; background: var(--accent); color: #fff; border: none;
    border-radius: 8px; padding: 16px; font-family: 'Heebo', sans-serif;
    font-weight: 800; font-size: 17px; cursor: pointer;
    transition: all var(--transition);
    display: flex; align-items: center; justify-content: center; gap: 8px;
  }
  .form-submit:hover { background: #0284c7; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(14,165,233,.3); }
  .form-note { font-size: 12px; color: var(--muted); text-align: center; margin-top: 12px; }

  /* ─── FOOTER ─── */
  footer {
    background: var(--ink);
    border-top: 1px solid rgba(255,255,255,.06);
    padding: 40px 60px;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 20px;
  }
  .footer-logo { font-family: 'Heebo', sans-serif; font-weight: 900; font-size: 20px; color: var(--accent); }
  .footer-logo span { color: var(--accent2); }
  .footer-text { font-size: 13px; color: var(--muted); }
  .footer-links { display: flex; gap: 20px; }
  .footer-links a { font-size: 13px; color: var(--muted); text-decoration: none; transition: color var(--transition); }
  .footer-links a:hover { color: var(--white); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    section { padding: 70px 24px; }
    .hero { padding: 80px 24px 50px; }
    nav { padding: 12px 20px; }
    .nav-links { display: none; }
    .compare-grid { grid-template-columns: 1fr; }
    .contact-layout { grid-template-columns: 1fr; gap: 36px; }
    .form-row { grid-template-columns: 1fr; }
    footer { padding: 30px 24px; flex-direction: column; align-items: flex-start; }
  }

  /* ─── ANIMATIONS ─── */
  .fade-in { opacity: 0; transform: translateY(22px); transition: opacity .6s ease, transform .6s ease; }
  .fade-in.visible { opacity: 1; transform: none; }

  /* WA float btn */
  .float-wa {
    position: fixed; bottom: 28px; left: 28px; z-index: 900;
    width: 58px; height: 58px; border-radius: 50%;
    background: #25d366; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; text-decoration: none;
    box-shadow: 0 4px 20px rgba(37,211,102,.5);
    animation: bounce 2s infinite;
  }
  @keyframes bounce {
    0%,100%{transform:translateY(0)}
    50%{transform:translateY(-6px)}
  }
</style>
</head>
<body>

<!-- ░░ STICKY BAR ░░ -->
<div class="sticky-bar">
  <div class="pulse"></div>
  <span>🚨 שירות חירום 24/7 — מענה תוך שעתיים באזור המרכז</span>
  <a href="tel:050-444-4878">📞 050-444-4878</a>
</div>

<!-- ░░ NAVBAR ░░ -->
<nav>
  <div class="nav-logo">MD<span>.</span>Tech</div>
  <ul class="nav-links">
    <li><a href="#services">שירותים</a></li>
    <li><a href="#how">איך זה עובד</a></li>
    <li><a href="#tech">הטכנולוגיה</a></li>
    <li><a href="#testimonials">לקוחות</a></li>
    <li><a href="#faq">שאלות נפוצות</a></li>
  </ul>
  <a href="#contact" class="nav-cta">קבל הצעת מחיר</a>
</nav>

<!-- ░░ HERO ░░ -->
<section class="hero">
